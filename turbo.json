{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "@command-center/api#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": [
        "PORT",
        "CORS_ORIGIN",
        "SUPABASE_URL",
        "SUPABASE_PUBLISHABLE_KEY",
        "SUPABASE_JWT_SECRET",
        "SUPABASE_JWKS_URL"
      ]
    },
    "@command-center/contracts#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": [
        "CORS_ORIGIN",
        "SUPABASE_URL",
        "SUPABASE_PUBLISHABLE_KEY",
        "SUPABASE_JWT_SECRET",
        "SUPABASE_JWKS_URL"
      ]
    },
    "typecheck": { "dependsOn": ["^build"] },
    "lint": {},
    "test": { "dependsOn": ["^build"] },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
