{
  "$schema": "https://json.schemastore.org/tsconfig",
  // Deliberately self-contained (no `extends`): Vercel's nestjs preset
  // compiles this app itself but cannot resolve package-based extends
  // (@command-center/config/tsconfig.nest.json), which silently drops
  // `strict` and `emitDecoratorMetadata`. Options below mirror
  // tsconfig.nest.json + tsconfig.base.json — keep them in sync.
  "compilerOptions": {
    "target": "es2023",
    "lib": ["es2023"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "strictPropertyInitialization": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["jest", "node"],
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "incremental": true,
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist"]
}
